        { "key": "в”‚ у°Џ– Packages", "keyColor": "magenta", "type": "packages" },
        // Unterteilung wie in deinem Screenshot gewГјnscht
        { "key": "в”‚  в”њв”Ђ Pacman", "keyColor": "yellow", "type": "packages", "format": "{1}", "driver": "pacman" },
        { "key": "в”‚  в”њв”Ђ AUR   ", "keyColor": "cyan", "type": "packages", "format": "{1}", "driver": "aur" },
