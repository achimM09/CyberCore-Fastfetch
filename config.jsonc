            "text": "temp=$(curl -s 'wttr.in?format=%t' | grep -oE '[-+]?[0-9]+'); [ -z \"$temp\" ] && temp=0; awk -v t=\"$temp\" 'BEGIN {w=15; max=40; f=int(t*w/max); if(f>w)f=w; if(f<0)f=0; bar=\"\"; for(i=1;i<=w;i++) bar=bar ((i<=f)?\"в–€\":\"в–‘\"); print bar \" \" t \"В°C\"}'"
        },
        { "type": "custom", "format": "в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї" },

