        // --- BOX 2: HARDWARE ---
        { "type": "custom", "format": "в•­в”Ђв”Ђ Hardware Resources в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®" },
        {
            "type": "command",
            "key": "в”‚ п’ј CPU     ",
            "keyColor": "yellow",
            "text": "read _ u n s i io irq sirq st g gn < /proc/stat; t1=$((u+n+s+i+io+irq+sirq+st)); id1=$((i+io)); sleep 0.15; read _ u n s i io irq sirq st g gn < /proc/stat; t2=$((u+n+s+i+io+irq+sirq+st)); id2=$((i+io)); dt=$((t2-t1)); did=$((id2-id1)); p=$((100*(dt-did)/dt)); awk -v p=\"$p\" 'BEGIN {w=15; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"в–€\" : \"в–‘\"); print bar \" \" p \"%\"}'"
        },
        {
            "type": "command",
            "key": "в”‚ о‰¦ RAM     ",
            "keyColor": "yellow",
            "text": "awk '/MemTotal:/ {t=$2} /MemAvailable:/ {a=$2} END {p=int(((t-a)*100)/t); w=15; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"в–€\" : \"в–‘\"); print bar \" \" p \"%\"}' /proc/meminfo"
        },
        { "type": "command", "key": "в”‚ у°‹Љ Cloud   ", "keyColor": "yellow", "text": "df /mnt/cloud | awk 'NR==2 {p=$5; sub(/%/,\"\",p); w=15; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"в–€\" : \"в–‘\"); print bar \" \" p \"%\"}'" },
        { "type": "command", "key": "в”‚ у°‹Љ PassW   ", "keyColor": "yellow", "text": "df /mnt/PassW | awk 'NR==2 {p=$5; sub(/%/,\"\",p); w=15; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"в–€\" : \"в–‘\"); print bar \" \" p \"%\"}'" },
        { "type": "custom", "format": "в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї" },

        { "type": "custom", "format": "" },

        // --- BOX 3: SERVICES ---
        { "type": "custom", "format": "в•­в”Ђв”Ђ Self-Hosted Services в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®" },
        { "type": "command", "key": "в”‚ у°„„ Immich  ", "keyColor": "magenta", "text": "du -sh /mnt/cloud 2>/dev/null | awk '{print $1}' || echo 'n/a'" },
        { "type": "command", "key": "в”‚ у°џµ Vault   ", "keyColor": "magenta", "text": "du -sh /mnt/PassW 2>/dev/null | awk '{print $1}' || echo 'n/a'" },
        { "type": "custom", "format": "в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї" },

